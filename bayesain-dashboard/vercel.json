{
  "version": 2,
  "buildCommand": "npm install && cd client && npm install && npm run build && cp -r dist/* ../public/",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "public/bayesain.html",
      "externalNodeModules": ["yahoo-finance2", "@sparticuz/chromium-min", "puppeteer-core"]
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
