# Copy this to .env and fill in values
# On Railway, set these as environment variables in the dashboard

# Required: bcrypt hash of your team password
# Generate with: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',10));"
DASHBOARD_PASSWORD_HASH=

# Required: any long random string for session signing
SESSION_SECRET=

# Optional: defaults to 3004
PORT=3004

# Optional: set by Railway automatically for Puppeteer
# PUPPETEER_EXECUTABLE_PATH=
