# Vercel env vars — set these in the Vercel dashboard

# Required: bcrypt hash of team password
# Generate: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',10));"
DASHBOARD_PASSWORD_HASH=

# Required: any long random string
JWT_SECRET=

# Required: set automatically when you add Vercel Postgres integration
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Required: Anthropic API key for AI tweet generation (engage routes)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: Supabase project URL and anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional (local dev only)
PORT=3004
