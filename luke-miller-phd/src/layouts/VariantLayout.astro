---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '../styles/global.css';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import VariantSwitcher from '@components/VariantSwitcher.astro';

interface Props {
  title: string;
  description: string;
  /** CSS custom-property overrides applied to <html> to reskin the whole page. */
  styleVars: string;
  /** Optional raw <link> tags (e.g. Google Fonts) injected into <head>. */
  fontHead?: string;
  /** Slug of the active variant, for switcher highlighting. */
  variant: string;
}

const { title, description, styleVars, fontHead, variant } = Astro.props;
---

<!doctype html>
<html lang="en" style={styleVars}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Preview variants must not be indexed -->
    <meta name="robots" content="noindex, nofollow" />
    {fontHead && <Fragment set:html={fontHead} />}
  </head>
  <body class="bg-lm-bg text-lm-text font-sans min-h-screen flex flex-col">
    <VariantSwitcher active={variant} />

    <div class="h-1 w-full bg-lm-accent" aria-hidden="true"></div>
    <Nav />
    <main class="flex-1 w-full max-w-screen-xl mx-auto px-6 md:px-12 lg:px-20 py-12 md:py-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
