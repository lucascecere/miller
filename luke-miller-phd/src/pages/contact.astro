---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Contact | Luke Miller, PhD"
  description="Contact Luke Miller, Associate Professor of Finance at Saint Anselm College, for academic inquiries, research collaboration, or media requests."
>
  <div class="pt-2 pb-12 max-w-lg">
    <h1 class="font-serif text-3xl font-bold text-lm-text mb-3">Contact</h1>
    <p class="text-lm-muted text-sm leading-relaxed font-sans mb-8">
      For academic inquiries, research collaboration, or media requests, fill out the form below or email directly.
    </p>

    <!-- Direct email -->
    <a
      href="mailto:luke@bayesianmath.org"
      class="group inline-flex items-center gap-3 bg-lm-surface hover:bg-white border border-lm-border hover:border-lm-accent rounded-lg px-5 py-4 transition-all duration-200 mb-8"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-lm-accent shrink-0">
        <rect width="20" height="16" x="2" y="4" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
      <span class="font-sans text-lm-accent font-medium group-hover:underline">luke@bayesianmath.org</span>
    </a>

    <!-- Contact form -->
    <form
      id="contact-form"
      method="POST"
      action="/api/contact"
      class="bg-lm-surface rounded-lg p-6 border border-lm-border flex flex-col gap-5"
      novalidate
    >
      <!-- Honeypot -->
      <input type="text" name="_trap" class="hidden" aria-hidden="true" tabindex="-1" autocomplete="off" />

      <div class="flex flex-col gap-1.5">
        <label for="name" class="font-sans text-xs font-semibold uppercase tracking-wide text-lm-muted">
          Name <span class="text-red-400">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="font-sans text-sm text-lm-text bg-white border border-lm-border rounded-md px-3 py-2.5 w-full focus:outline-none focus:border-lm-accent transition-colors"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="email" class="font-sans text-xs font-semibold uppercase tracking-wide text-lm-muted">
          Email <span class="text-red-400">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="font-sans text-sm text-lm-text bg-white border border-lm-border rounded-md px-3 py-2.5 w-full focus:outline-none focus:border-lm-accent transition-colors"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="message" class="font-sans text-xs font-semibold uppercase tracking-wide text-lm-muted">
          Message <span class="text-red-400">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          class="font-sans text-sm text-lm-text bg-white border border-lm-border rounded-md px-3 py-2.5 w-full focus:outline-none focus:border-lm-accent transition-colors resize-y"
        ></textarea>
      </div>

      <div class="flex items-center gap-4">
        <button
          type="submit"
          id="submit-btn"
          class="font-sans text-sm font-medium bg-lm-accent text-white px-5 py-2.5 rounded-md hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Message
        </button>
        <p id="form-status" class="text-sm font-sans hidden"></p>
      </div>
    </form>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.className = 'text-sm font-sans hidden';
    status.textContent = '';

    try {
      const res  = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      const data = await res.json();

      if (data.success) {
        form.reset();
        status.textContent = 'Message sent. Thank you — I will be in touch.';
        status.className = 'text-sm font-sans text-green-700';
      } else {
        status.textContent = data.error ?? 'Something went wrong. Please try again.';
        status.className = 'text-sm font-sans text-red-600';
      }
    } catch {
      status.textContent = 'Failed to send. Please email directly.';
      status.className = 'text-sm font-sans text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
