---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import ResearchCard from '@components/ResearchCard.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import headshot from '../../public/Luke+Miller.webp';

const allPosts = await getCollection('research', ({ data }) => !data.draft);
const featured = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<Layout
  title="Luke Miller, PhD — Finance Professor, Saint Anselm College"
  description="Dr. Luke Miller is an Associate Professor of Finance at Saint Anselm College and creator of BayesAIn Strategies — a leading expert in Bayesian inference, real options valuation, and financial decision-making under uncertainty."
>
  <!-- Identity section — two-column at lg -->
  <section class="pt-8 pb-16 border-b border-lm-border">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left: text -->
      <div class="order-last lg:order-first">
        <p class="font-mono text-xs tracking-widest uppercase text-lm-muted mb-5">
          Creator of BayesAIn Strategies
        </p>
        <h1 class="font-serif text-4xl sm:text-5xl font-normal text-lm-text leading-tight tracking-tight mb-6">
          Luke Miller, PhD
        </h1>
        <div class="flex flex-col gap-4 font-sans text-base leading-relaxed text-lm-text-muted mb-8">
          <p>Dr. Luke Miller is a finance professor and consultant with nearly 30 years of experience developing Bayesian learning algorithms for complex decision-making systems across a wide range of industries.</p>
          <p>His work applies a proprietary probabilistic framework — grounded in Bayesian inference — to help organizations navigate uncertainty, evaluate risk, and improve strategic outcomes.</p>
          <p>Dr. Miller&rsquo;s consulting practice spans a broad cross-section of industries, with particular depth in financial services. He has advised institutions such as Morningstar, Neuberger Berman, American Express, Ventas, and StanCorp Financial Group, along with numerous hedge funds, family offices, and nonprofit endowments.</p>
          <p>Dr. Miller currently serves as a finance professor in the Economics &amp; Business Department at Saint Anselm College.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-lm-border text-lm-muted">Real Options</span>
          <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-lm-border text-lm-muted">Bayesian Methods</span>
          <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-lm-border text-lm-muted">Financial Engineering</span>
          <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-lm-border text-lm-muted">Capital Budgeting</span>
          <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-lm-border text-lm-muted">Investment Under Uncertainty</span>
        </div>
      </div>

      <!-- Right: headshot -->
      <div class="order-first lg:order-last flex justify-center lg:justify-end">
        <div class="w-56 sm:w-64 lg:w-72 overflow-hidden rounded-sm border border-lm-border">
          <Image
            src={headshot}
            alt="Luke Miller, PhD — Finance Professor, Saint Anselm College"
            width={360}
            height={420}
            class="w-full h-auto object-cover object-top"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- As Featured In -->
  <section class="py-10 border-b border-lm-border">
    <p class="font-mono text-xs tracking-widest uppercase text-lm-muted mb-7 text-center">As Featured In</p>
    <LogoMarquee />
  </section>

  <!-- Book -->
  <section class="py-16 border-b border-lm-border">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left: cover -->
      <div class="flex justify-center lg:justify-start">
        <a
          href="https://www.amazon.com/Development-Bayesian-Real-Options-Framework/dp/3639282922"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-48 sm:w-56 overflow-hidden rounded-sm border border-lm-border hover:border-lm-accent transition-colors duration-200"
        >
          <img
            src="/book-cover.jpg"
            alt="Development of a Bayesian Real Options Framework book cover"
            width="224"
            height="320"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </a>
      </div>

      <!-- Right: details -->
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-lm-muted mb-5">Published Work</p>
        <h2 class="font-serif text-2xl sm:text-3xl font-normal text-lm-text leading-snug mb-3">
          Development of a Bayesian Real Options Framework
        </h2>
        <p class="font-serif text-lg italic text-lm-muted mb-4">
          And Its Application to Capital Budgeting Problems
        </p>
        <p class="font-mono text-xs text-lm-muted tracking-wide mb-6">
          VDM Verlag &middot; 2010
        </p>
        <p class="font-sans text-sm leading-relaxed text-lm-text-muted mb-8">
          This book presents a rigorous Bayesian learning framework for evaluating capital investment decisions under uncertainty. Rooted in Dr. Miller&rsquo;s doctoral research, it develops a probabilistic methodology that dynamically incorporates new information into real options valuations — providing decision-makers with a principled approach to investment timing, deferral, and abandonment across industries including financial services, aerospace, and operations management.
        </p>
        <a
          href="https://www.amazon.com/Development-Bayesian-Real-Options-Framework/dp/3639282922"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-lm-accent text-white font-sans text-sm font-medium px-5 py-2.5 rounded-sm hover:opacity-90 transition-opacity"
        >
          View on Amazon
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>

    </div>
  </section>

  <!-- Featured Research -->
  <section class="py-12">
    <p class="font-mono text-xs tracking-widest uppercase text-lm-muted mb-3">Research</p>
    <h2 class="font-serif text-2xl font-normal text-lm-text mb-1">Recent Publications</h2>
    <p class="text-sm text-lm-muted font-sans mb-8">Working papers and peer-reviewed publications.</p>
    <div class="flex flex-col gap-3">
      {featured.map((post) => (
        <ResearchCard
          title={post.data.title}
          date={post.data.date}
          category={post.data.category}
          tags={post.data.tags}
          summary={post.data.summary}
          slug={post.id}
        />
      ))}
    </div>
    <div class="mt-8">
      <a href="/research" class="inline-flex items-center gap-1.5 text-sm text-lm-accent hover:text-lm-text transition-colors font-sans font-medium">
        View all research &rarr;
      </a>
    </div>
  </section>
</Layout>
