---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import ResearchCard from '@components/ResearchCard.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import headshot from '../../public/Luke+Miller.webp';

const allPosts = await getCollection('research', ({ data }) => !data.draft);
const featured = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<Layout
  title="Luke Miller, PhD — Finance Professor, Saint Anselm College"
  description="Luke Miller is a finance professor at Saint Anselm College with nearly 30 years of experience in Bayesian methods, real options, and financial engineering."
>
  <!-- Identity section -->
  <section class="flex flex-col gap-6 pt-2 pb-12 border-b border-lm-border">
    <Image
      src={headshot}
      alt="Luke Miller, PhD — Finance Professor, Saint Anselm College"
      width={160}
      height={160}
      class="w-40 h-40 object-cover object-center rounded-md border border-lm-border self-center sm:self-start"
      loading="eager"
      fetchpriority="high"
    />
    <div>
      <h1 class="font-serif text-3xl font-normal text-lm-text tracking-tight leading-tight">
        Luke Miller, PhD
      </h1>
      <p class="text-lm-muted font-sans text-sm mt-1.5">
        Associate Professor of Finance &middot; Saint Anselm College
      </p>
    </div>
    <div class="flex flex-col gap-4 max-w-prose font-sans text-base leading-relaxed text-lm-text">
      <p>Dr. Luke Miller is a finance professor and consultant with nearly 30 years of experience developing Bayesian learning algorithms for complex decision-making systems across a wide range of industries.</p>
      <p>His work applies a proprietary probabilistic framework — grounded in Bayesian inference — to help organizations navigate uncertainty, evaluate risk, and improve strategic outcomes.</p>
      <p>Dr. Miller&rsquo;s consulting practice spans a broad cross-section of industries, with particular depth in financial services. He has advised institutions such as Morningstar, Neuberger Berman, American Express, Ventas, and StanCorp Financial Group, along with numerous hedge funds, family offices, and nonprofit endowments.</p>
      <p>Dr. Miller currently serves as a finance professor in the Economics &amp; Business Department at Saint Anselm College.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <span class="text-xs font-sans font-medium px-3 py-1.5 rounded-full border border-lm-accent text-lm-accent bg-lm-surface">Real Options</span>
      <span class="text-xs font-sans font-medium px-3 py-1.5 rounded-full border border-lm-accent text-lm-accent bg-lm-surface">Bayesian Methods</span>
      <span class="text-xs font-sans font-medium px-3 py-1.5 rounded-full border border-lm-accent text-lm-accent bg-lm-surface">Financial Engineering</span>
      <span class="text-xs font-sans font-medium px-3 py-1.5 rounded-full border border-lm-accent text-lm-accent bg-lm-surface">Capital Budgeting</span>
      <span class="text-xs font-sans font-medium px-3 py-1.5 rounded-full border border-lm-accent text-lm-accent bg-lm-surface">Investment Under Uncertainty</span>
    </div>
  </section>

  <!-- As Featured In -->
  <section class="py-10 border-b border-lm-border">
    <p class="text-xs font-sans font-semibold uppercase tracking-widest text-lm-muted mb-7 text-center">As Featured In</p>
    <LogoMarquee />
  </section>

  <!-- Featured Research -->
  <section class="py-12">
    <h2 class="font-serif text-xl font-semibold text-lm-text mb-1">Recent Research</h2>
    <p class="text-sm text-lm-muted font-sans mb-6">Working papers and publications.</p>
    <div class="flex flex-col gap-3">
      {featured.map((post) => (
        <ResearchCard
          title={post.data.title}
          date={post.data.date}
          category={post.data.category}
          tags={post.data.tags}
          summary={post.data.summary}
          slug={post.id}
        />
      ))}
    </div>
    <div class="mt-6">
      <a href="/research" class="text-sm text-lm-accent hover:underline font-sans font-medium">
        View all research &rarr;
      </a>
    </div>
  </section>
</Layout>
