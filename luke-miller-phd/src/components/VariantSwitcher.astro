---
interface Props {
  active: string;
}
const { active } = Astro.props;

const links = [
  { slug: 'current',   href: '/',                   label: 'Current' },
  { slug: 'ivory',     href: '/variants/ivory',     label: 'Ivory' },
  { slug: 'spotlight', href: '/variants/spotlight', label: 'Spotlight' },
  { slug: 'quant',     href: '/variants/quant',     label: 'Quant' },
];
---

<div class="w-full bg-lm-surface border-b border-lm-border">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12 lg:px-20 py-2 flex items-center gap-4 flex-wrap">
    <span class="font-mono text-[10px] uppercase tracking-widest text-lm-muted">Preview</span>
    <div class="flex items-center gap-1.5 flex-wrap">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'font-mono text-[11px] px-2.5 py-1 rounded-full border transition-colors',
            l.slug === active
              ? 'border-lm-accent text-lm-text bg-lm-accent/10'
              : 'border-lm-border text-lm-muted hover:text-lm-text hover:border-lm-accent/50',
          ]}
        >
          {l.label}
        </a>
      ))}
    </div>
  </div>
</div>
